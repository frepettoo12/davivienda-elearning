rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Multi-tenant: los uploads los hacen las Cloud Functions / agent-service
    // con Admin SDK (bypasea reglas) y la lectura pública va por ACL de GCS
    // (make_public), no por estas reglas. Cerrado para clientes.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
