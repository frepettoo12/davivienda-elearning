rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir lectura pública de audio y video
    match /audio/{fileName} {
      allow read: if true;
      allow write: if true;  // Ajustar cuando agreguemos auth
    }
    match /video/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    match /scorm/{fileName} {
      allow read: if true;
      allow write: if true;
    }
  }
}
